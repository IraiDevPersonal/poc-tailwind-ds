---
import DeviceCard from "../components/DeviceCard.astro";
import Slider from "../components/slider/Slider.astro";
import SliderContent from "../components/slider/SliderContent.astro";
import SliderDots from "../components/slider/SliderDots.astro";
import Slides from "../components/slider/Slides.astro";
import RootLayout from "../layouts/RootLayout.astro";
---

<RootLayout>
  <Slider>
    <SliderContent>
      <Slides id="devices" className="max-w-5xl">
        {
          Array.from({ length: 10 }).map((_, index) => (
            <DeviceCard index={index} />
          ))
        }
      </Slides>
      <SliderDots id="devices" />
    </SliderContent>
  </Slider>
</RootLayout>

<script>
  import { SliderProvider } from "../components/slider/slider-provider";

  new SliderProvider("#devices", {
    sliderOptions: { showDots: true },
    mountOnInit: true,
  });
</script>
