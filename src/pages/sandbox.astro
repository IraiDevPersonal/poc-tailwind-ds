---
import DeviceSlide from "@components/DeviceSlide.astro";
import DeviceThumbnail from "@components/DeviceThumbnail.astro";
import GallerySlide from "@components/GallerySlide.astro";
import SlideFallback from "@components/slider/SlideFallback.astro";
import Slider from "@components/slider/Slider.astro";
import SliderWrapper from "@components/slider/SliderWrapper.astro";
import SliderDots from "@components/slider/SliderDots.astro";
import SliderThumbnails from "@components/slider/SliderThumbnails.astro";
import Slides from "@components/slider/Slides.astro";
import RootLayout from "@layouts/RootLayout.astro";
import { DEVICE_SLIDER_ID, GALLERY_SLIDER_ID } from "@lib/constants";
import SliderNavButtons from "@components/slider/SliderNavButtons.astro";

const products = Array.from({ length: 7 }).map((_, index) => ({
  id: index + 1,
  name: `producto ${index + 1}`,
}));
---

<RootLayout>
  <Slider
    className="mx-auto w-max"
    theme={{
      "--slider-height": "320px",
      "--thumbnail-width": "60px",
      "--slider-main-width": "320px",
    }}
  >
    <SliderThumbnails
      render={DeviceThumbnail}
      id={GALLERY_SLIDER_ID}
      items={products}
    >
      <SlideFallback as="li" className="size-12 rounded-lg" textContent="" />
    </SliderThumbnails>
    <SliderWrapper>
      <SliderNavButtons id={GALLERY_SLIDER_ID} />
      <Slides id={GALLERY_SLIDER_ID} render={GallerySlide} items={products}>
        <SlideFallback
          className="rounded-[16px] h-full"
          textContent="Sin imagenes para mostrar"
        />
      </Slides>
      <SliderDots
        id={GALLERY_SLIDER_ID}
        className="absolute bottom-5 left-1/2 -translate-x-1/2"
      />
    </SliderWrapper>
  </Slider>

  <Slider className="max-w-5xl mx-auto" theme={{ "--slider-gap": "20px" }}>
    <SliderWrapper>
      <Slides
        id={DEVICE_SLIDER_ID}
        className="max-w-5xl"
        render={DeviceSlide}
        items={products}
      />
      <SliderDots id={DEVICE_SLIDER_ID} />
    </SliderWrapper>
  </Slider>
</RootLayout>

<script>
  import { SliderProvider } from "@components/slider/slider-provider";
  import { DEVICE_SLIDER_ID, GALLERY_SLIDER_ID } from "@lib/constants";

  new SliderProvider(DEVICE_SLIDER_ID, { sliderOptions: { showDots: true } });

  new SliderProvider(GALLERY_SLIDER_ID, {
    sliderOptions: {
      showNavButtons: true,
      showThumbnails: true,
      showDots: true,
      skipSnaps: false,
      dragFree: false,
      loop: true,
    },
  });
</script>
