---
import SandboxLayout from "@layouts/SandboxLayout.astro";
import "../components/carousel-3d/carousel-3d.css";
import SliderNavButtons from "@components/slider/SliderNavButtons.astro";
import SliderDots from "@components/slider/SliderDots.astro";

const SLIDER_ID = "destinations-slider";

const destinations = [
  {
    name: "Spain",
    flag: "\u{1F1EA}\u{1F1F8}",
    image: "/images/spain.jpg",
    description:
      "Sun-drenched beaches and vibrant culture along the Mediterranean coast.",
  },
  {
    name: "Maldives",
    flag: "\u{1F1F2}\u{1F1FB}",
    image: "/images/maldives.jpg",
    description: "Crystal-clear waters and overwater bungalows in paradise.",
  },
  {
    name: "Malta",
    flag: "\u{1F1F2}\u{1F1F9}",
    image: "/images/malta.jpg",
    description:
      "Historic temples and stunning blue lagoons in the Mediterranean.",
  },
  {
    name: "Indonesia",
    flag: "\u{1F1EE}\u{1F1E9}",
    image: "/images/indonesia.jpg",
    description:
      "Tropical islands with world-class surfing and ancient temples.",
  },
  {
    name: "Turkey",
    flag: "\u{1F1F9}\u{1F1F7}",
    image: "/images/turkey.jpg",
    description:
      "Where East meets West with stunning coastlines and rich history.",
  },
  {
    name: "Barbados",
    flag: "\u{1F1E7}\u{1F1E7}",
    image: "/images/barbados.jpg",
    description: "Caribbean charm with pink sand beaches and rum distilleries.",
  },
  {
    name: "Greece",
    flag: "\u{1F1EC}\u{1F1F7}",
    image: "/images/greece.jpg",
    description:
      "Whitewashed villages and turquoise coves around every corner.",
  },
  {
    name: "Portugal",
    flag: "\u{1F1F5}\u{1F1F9}",
    image: "/images/portugal.jpg",
    description: "Golden Algarve cliffs and charming coastal towns.",
  },
  {
    name: "Thailand",
    flag: "\u{1F1F9}\u{1F1ED}",
    image: "/images/thailand.jpg",
    description:
      "Emerald waters, jungle-covered limestone karsts, and golden temples.",
  },
  {
    name: "Mauritius",
    flag: "\u{1F1F2}\u{1F1FA}",
    image: "/images/mauritius.jpg",
    description: "Volcanic island paradise with coral reefs and lush forests.",
  },
  {
    name: "Cyprus",
    flag: "\u{1F1E8}\u{1F1FE}",
    image: "/images/cyprus.jpg",
    description: "Mythical birthplace of Aphrodite with golden sandy beaches.",
  },
  {
    name: "Italy",
    flag: "\u{1F1EE}\u{1F1F9}",
    image: "/images/italy.jpg",
    description:
      "Amalfi Coast dreams, Sardinian coves, and world-renowned cuisine.",
  },
  {
    name: "Croatia",
    flag: "\u{1F1ED}\u{1F1F7}",
    image: "/images/croatia.jpg",
    description:
      "Adriatic jewel with medieval walled cities and island-hopping adventures.",
  },
];
---

<SandboxLayout>
  <main
    class="flex flex-col items-center justify-center min-h-dvh py-12 px-4 bg-gray-100"
  >
    <h2 class="text-2xl font-bold text-gray-800 mb-8 text-center tracking-tight">
      Top Destinations
    </h2>

    <!-- Swap container: placeholder visible on SSR, real slider replaces it after JS -->
    <div class="c3d-swap-container w-full max-w-[700px] mx-auto">

      <!-- Placeholder (3 static cards shown before JS loads) -->
      <div class="c3d-placeholder" id="dest-placeholder">
        <div class="c3d-placeholder-card c3d-placeholder-left">
          <div class="c3d-card-content">
            <img src={destinations[10].image} alt={destinations[10].name} />
            <div class="c3d-card-gradient"></div>
            <div class="c3d-card-info">
              <h3>{destinations[10].flag} {destinations[10].name}</h3>
              <p>Click to learn more</p>
            </div>
          </div>
        </div>
        <div class="c3d-placeholder-card c3d-placeholder-center">
          <div class="c3d-card-content">
            <img src={destinations[11].image} alt={destinations[11].name} />
            <div class="c3d-card-gradient"></div>
            <div class="c3d-card-info">
              <h3>{destinations[11].flag} {destinations[11].name}</h3>
              <p>Click to learn more</p>
            </div>
          </div>
        </div>
        <div class="c3d-placeholder-card c3d-placeholder-right">
          <div class="c3d-card-content">
            <img src={destinations[12].image} alt={destinations[12].name} />
            <div class="c3d-card-gradient"></div>
            <div class="c3d-card-info">
              <h3>{destinations[12].flag} {destinations[12].name}</h3>
              <p>Click to learn more</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Real slider (hidden until JS is ready) -->
      <div id="dest-real" class="c3d c3d-real-hidden dest-3d-wrap">
        <SliderNavButtons id={SLIDER_ID} />
        <!-- Embla viewport -->
        <div id={SLIDER_ID} class="dest-3d-viewport">
          <!-- Embla container (first child = scroll container) -->
          <div class="dest-3d-container">
            {
              destinations.map((dest) => (
                <div class="dest-3d-slide">
                  <div class="c3d-card-content">
                    <img src={dest.image} alt={dest.name} loading="lazy" />
                    <div class="c3d-card-gradient" />
                    <div class="c3d-card-info">
                      <h3>
                        {dest.flag} {dest.name}
                      </h3>
                      <p>Click to learn more</p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>

    </div>

    <SliderDots id={SLIDER_ID} className="mt-6" />

    <div class="c3d-description-area">
      <p id="dest-description">{destinations[11].description}</p>
    </div>
  </main>
</SandboxLayout>

<script>
  import { SliderProvider } from "@components/slider/slider-provider";

  const SLIDER_ID = "destinations-slider";

  const descriptions = [
    "Sun-drenched beaches and vibrant culture along the Mediterranean coast.",
    "Crystal-clear waters and overwater bungalows in paradise.",
    "Historic temples and stunning blue lagoons in the Mediterranean.",
    "Tropical islands with world-class surfing and ancient temples.",
    "Where East meets West with stunning coastlines and rich history.",
    "Caribbean charm with pink sand beaches and rum distilleries.",
    "Whitewashed villages and turquoise coves around every corner.",
    "Golden Algarve cliffs and charming coastal towns.",
    "Emerald waters, jungle-covered limestone karsts, and golden temples.",
    "Volcanic island paradise with coral reefs and lush forests.",
    "Mythical birthplace of Aphrodite with golden sandy beaches.",
    "Amalfi Coast dreams, Sardinian coves, and world-renowned cuisine.",
    "Adriatic jewel with medieval walled cities and island-hopping adventures.",
  ];

  new SliderProvider(SLIDER_ID, {
    sliderOptions: {
      showNavButtons: true,
      showDots: true,
      align: "center",
      loop: true,
      dragFree: false,
      skipSnaps: false,
      containScroll: false,
      startIndex: 11, // start on Italy (index 11)
    },
    classNames: {
      dot: "size-2 rounded-full bg-gray-400 transition-all duration-300 outline-none",
      dotActive: "!w-5 bg-gray-700",
    },
  });

  const wrapper = document.getElementById("dest-real")!;
  const viewport = document.getElementById(SLIDER_ID)!;
  const container = viewport.firstElementChild as HTMLElement;
  const slides = Array.from(container.children) as HTMLElement[];
  const placeholder = document.getElementById("dest-placeholder")!;
  const descEl = document.getElementById("dest-description")!;

  // Allow adjacent slides to overflow the viewport for the 3D coverflow effect
  viewport.style.overflow = "visible";

  function applyTweens() {
    const wrapperRect = wrapper.getBoundingClientRect();
    const centerX = wrapperRect.left + wrapperRect.width / 2;

    let activeIndex = 0;
    let minDist = Infinity;

    slides.forEach((slide, i) => {
      const rect = slide.getBoundingClientRect();
      const slideCenter = rect.left + rect.width / 2;
      const dist = (slideCenter - centerX) / rect.width;
      const absDist = Math.abs(dist);

      if (absDist < minDist) {
        minDist = absDist;
        activeIndex = i;
      }

      if (absDist > 2.5) {
        slide.style.opacity = "0";
        slide.style.zIndex = "0";
        return;
      }

      const scale = Math.max(0.65, 1 - absDist * 0.175);
      const rotateY = -Math.sign(dist) * Math.min(absDist * 22, 25);
      const opacity =
        absDist > 1.8 ? Math.max(0, 1 - (absDist - 1.8) * 2.5) : 1;

      slide.style.transform = `perspective(1050px) scale(${scale}) rotateY(${rotateY}deg)`;
      slide.style.opacity = String(opacity);
      slide.style.zIndex = String(Math.round(30 - absDist * 10));
    });

    // Update description when settled on a slide
    if (minDist < 0.25) {
      descEl.textContent = descriptions[activeIndex] ?? "";
    }
  }

  // Fire tween on every Embla container transform update
  new MutationObserver(applyTweens).observe(container, {
    attributes: true,
    attributeFilter: ["style"],
  });

  // Swap placeholder → real slider
  setTimeout(() => {
    wrapper.classList.remove("c3d-real-hidden");
    placeholder.style.display = "none";
    applyTweens();
  }, 400);
</script>

<style>
  /* ============================
     Card content
     ============================ */
  .c3d-card-content {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 25px;
    overflow: hidden;
    background: #fff;
  }

  .c3d-card-content > img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .c3d-card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.6),
      rgba(0, 0, 0, 0.1) 50%,
      transparent
    );
    pointer-events: none;
  }

  .c3d-card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px;
  }

  .c3d-card-info h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
  }

  .c3d-card-info p {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 2px;
  }

  /* ============================
     Real 3D slider
     ============================ */
  .dest-3d-wrap {
    height: 420px;
  }

  .dest-3d-viewport {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
  }

  .dest-3d-container {
    display: flex;
    align-items: center;
    height: 340px;
    gap: 16px;
  }

  .dest-3d-slide {
    flex: none;
    width: 260px;
    height: 340px;
    border-radius: 25px;
    overflow: hidden;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.15),
      0 5px 15px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.08s linear,
      opacity 0.08s linear;
    will-change: transform, opacity;
  }

  /* ============================
     Placeholder static cards
     ============================ */
  .c3d-placeholder {
    position: relative;
    width: 100%;
    height: 420px;
    perspective: 1050px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .c3d-placeholder-card {
    position: absolute;
    width: 260px;
    height: 340px;
    border-radius: 25px;
    overflow: hidden;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.15),
      0 5px 15px rgba(0, 0, 0, 0.08);
  }

  .c3d-placeholder-center {
    transform: translateX(0px) scale(1) rotateY(0deg);
    z-index: 30;
  }

  .c3d-placeholder-left {
    transform: translateX(-220px) scale(0.8) rotateY(21deg);
    z-index: 20;
  }

  .c3d-placeholder-right {
    transform: translateX(220px) scale(0.8) rotateY(-21deg);
    z-index: 20;
  }

  /* ============================
     Description area
     ============================ */
  .c3d-description-area {
    text-align: center;
    margin-top: 24px;
    min-height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .c3d-description-area p {
    color: #4b5563;
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 500px;
    transition: opacity 0.3s ease;
  }

  /* ============================
     Responsive
     ============================ */
  @media (max-width: 1023px) and (min-width: 640px) {
    .c3d-placeholder {
      height: 360px;
      perspective: 800px;
    }
    .c3d-placeholder-card {
      width: 220px;
      height: 290px;
    }
    .c3d-placeholder-left {
      transform: translateX(-187px) scale(0.8) rotateY(21deg);
    }
    .c3d-placeholder-right {
      transform: translateX(187px) scale(0.8) rotateY(-21deg);
    }
    .dest-3d-wrap {
      height: 360px;
    }
    .dest-3d-slide {
      width: 220px;
      height: 290px;
    }
    .dest-3d-container {
      height: 290px;
    }
  }

  @media (max-width: 639px) {
    .c3d-placeholder {
      height: 320px;
      perspective: 600px;
    }
    .c3d-placeholder-card {
      width: 200px;
      height: 260px;
    }
    .c3d-placeholder-left {
      transform: translateX(-154px) scale(0.8) rotateY(21deg);
    }
    .c3d-placeholder-right {
      transform: translateX(154px) scale(0.8) rotateY(-21deg);
    }
    .dest-3d-wrap {
      height: 320px;
    }
    .dest-3d-slide {
      width: 200px;
      height: 260px;
    }
    .dest-3d-container {
      height: 260px;
    }
  }
</style>
