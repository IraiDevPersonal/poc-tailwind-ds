---
import Carousel3D from "@components/carousel-3d/Carousel3d.astro";
import Carousel3DItem from "@components/carousel-3d/Carousel3dItem.astro";
import DeviceThumbnail from "@components/DeviceThumbnail.astro";
import GalleryFallback from "@components/GalleryFallback.astro";
import GallerySlide from "@components/GallerySlide.astro";
import Slider from "@components/slider/Slider.astro";
import SliderDots from "@components/slider/SliderDots.astro";
import SliderNavButtons from "@components/slider/SliderNavButtons.astro";
import SliderThumbnailsWrapper from "@components/slider/SliderThumbnailsWrapper.astro";
import SliderWrapper from "@components/slider/SliderWrapper.astro";
import Slides from "@components/slider/Slides.astro";
import RootLayout from "@layouts/RootLayout.astro";
import { GALLERY_SLIDER_ID } from "@lib/constants";
import Carousel3DSlides from "@components/carousel-3d/Carousel3dSlides.astro";
import Carousel3dPlaceholder from "@components/carousel-3d/Carousel3dPlaceholder.astro";
import Carousel3DPlaceholderItem from "@components/carousel-3d/Carousel3dPlaceholderItem.astro";
import TestCard from "@components/TestCard.astro";

const products = Array.from({ length: 7 }).map((_, index) => ({
  id: index + 1,
  name: `producto ${index + 1}`,
}));

const destinations = [
  {
    name: "Spain",
    flag: "\u{1F1EA}\u{1F1F8}",
    image: "/images/spain.jpg",
    description:
      "Sun-drenched beaches and vibrant culture along the Mediterranean coast.",
  },
  {
    name: "Maldives",
    flag: "\u{1F1F2}\u{1F1FB}",
    image: "/images/maldives.jpg",
    description: "Crystal-clear waters and overwater bungalows in paradise.",
  },
  {
    name: "Malta",
    flag: "\u{1F1F2}\u{1F1F9}",
    image: "/images/malta.jpg",
    description:
      "Historic temples and stunning blue lagoons in the Mediterranean.",
  },
  {
    name: "Indonesia",
    flag: "\u{1F1EE}\u{1F1E9}",
    image: "/images/indonesia.jpg",
    description:
      "Tropical islands with world-class surfing and ancient temples.",
  },
  {
    name: "Turkey",
    flag: "\u{1F1F9}\u{1F1F7}",
    image: "/images/turkey.jpg",
    description:
      "Where East meets West with stunning coastlines and rich history.",
  },
  {
    name: "Barbados",
    flag: "\u{1F1E7}\u{1F1E7}",
    image: "/images/barbados.jpg",
    description: "Caribbean charm with pink sand beaches and rum distilleries.",
  },
  {
    name: "Greece",
    flag: "\u{1F1EC}\u{1F1F7}",
    image: "/images/greece.jpg",
    description:
      "Whitewashed villages and turquoise coves around every corner.",
  },
  {
    name: "Portugal",
    flag: "\u{1F1F5}\u{1F1F9}",
    image: "/images/portugal.jpg",
    description: "Golden Algarve cliffs and charming coastal towns.",
  },
  {
    name: "Thailand",
    flag: "\u{1F1F9}\u{1F1ED}",
    image: "/images/thailand.jpg",
    description:
      "Emerald waters, jungle-covered limestone karsts, and golden temples.",
  },
  {
    name: "Mauritius",
    flag: "\u{1F1F2}\u{1F1FA}",
    image: "/images/mauritius.jpg",
    description: "Volcanic island paradise with coral reefs and lush forests.",
  },
  {
    name: "Cyprus",
    flag: "\u{1F1E8}\u{1F1FE}",
    image: "/images/cyprus.jpg",
    description: "Mythical birthplace of Aphrodite with golden sandy beaches.",
  },
  {
    name: "Italy",
    flag: "\u{1F1EE}\u{1F1F9}",
    image: "/images/italy.jpg",
    description:
      "Amalfi Coast dreams, Sardinian coves, and world-renowned cuisine.",
  },
  {
    name: "Croatia",
    flag: "\u{1F1ED}\u{1F1F7}",
    image: "/images/croatia.jpg",
    description:
      "Adriatic jewel with medieval walled cities and island-hopping adventures.",
  },
];

function getPlaceholder() {
  return {
    left: destinations.at(-1),
    center: destinations.at(0),
    right: destinations.at(1),
  };
}

const placeholders = getPlaceholder();
---

<RootLayout>
  <Carousel3D>
    <Carousel3dPlaceholder id="placeholder">
      <Carousel3DPlaceholderItem position="left">
        <TestCard {...placeholders.left!} />
      </Carousel3DPlaceholderItem>
      <Carousel3DPlaceholderItem position="center">
        <TestCard {...placeholders.center!} />
      </Carousel3DPlaceholderItem>
      <Carousel3DPlaceholderItem position="right">
        <TestCard {...placeholders.right!} />
      </Carousel3DPlaceholderItem>
    </Carousel3dPlaceholder>

    <Carousel3DSlides id="mi-carousel">
      {
        destinations.map((dest) => (
          <Carousel3DItem data-carousel-card>
            <TestCard {...dest} />
          </Carousel3DItem>
        ))
      }
    </Carousel3DSlides>
  </Carousel3D>
  <!-- Ejemplo para Slider Gallery -->
  <Slider
    className="mx-auto w-max"
    theme={{
      "--slider-height": "320px",
      "--slider-wrapper-width": "320px",
    }}
  >
    <SliderThumbnailsWrapper
      render={DeviceThumbnail}
      id={GALLERY_SLIDER_ID}
      items={products}
    />
    <SliderWrapper>
      <SliderNavButtons id={GALLERY_SLIDER_ID} />
      <Slides
        fallback={GalleryFallback}
        id={GALLERY_SLIDER_ID}
        render={GallerySlide}
        items={products}
      />
      <SliderDots
        id={GALLERY_SLIDER_ID}
        className="absolute bottom-5 left-1/2 -translate-x-1/2"
      />
    </SliderWrapper>
  </Slider>
</RootLayout>

<script>
  import { Carousel3D } from "@components/carousel-3d";
  import { SliderProvider } from "@components/slider/slider-provider";
  import { GALLERY_SLIDER_ID } from "@lib/constants";

  new Carousel3D(document.getElementById("mi-carousel")!, {
    placeholderSelector: "#placeholder",
    visibleCards: 3,
    infinite: true,
    showArrows: false,
    rotateY: 55,
    translateX: 235,
  });

  new SliderProvider(GALLERY_SLIDER_ID, {
    sliderOptions: {
      showNavButtons: true,
      showThumbnails: true,
      showDots: true,
      skipSnaps: false,
      dragFree: false,
      loop: true,
    },
  });
</script>
