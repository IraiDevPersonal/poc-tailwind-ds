---
import image from "@assets/slider-img.png";

type Props = {
  index: number;
  id: number;
  name: string;
};

const { index, name, id } = Astro.props;
---

<div
  class="flex-none w-50 h-50 bg-white rounded-2xl shadow p-4 flex flex-col selection:bg-transparent"
>
  <p class="font-bold text-lg">
    Apple <span class="text-red-500">{id}</span>
  </p>
  <p class="font-semibold text-gray-800 mb-3">iPhone 17 - {name}</p>
  <img
    src={image.src}
    alt={`iPhone 17 - Apple ${index + 1}`}
    class="w-full object-contain h-40"
  />
</div>
