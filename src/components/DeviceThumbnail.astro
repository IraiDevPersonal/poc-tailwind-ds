---
import image from "@assets/slider-img.png";
import SliderThumbnail from "./slider/SliderThumbnail.astro";

type Props = {
  name: string;
};

const { name } = Astro.props;
---

<SliderThumbnail>
  <img
    class="w-full h-full object-contain object-center"
    src={image.src}
    alt={name}
  />
</SliderThumbnail>
