---
import { cn } from "@lib/utils";
import type { HTMLTag } from "astro/types";

type Props<T extends HTMLTag = "div"> = {
  textContent?: string;
  className?: string;
  as?: T;
};

const { className, textContent, as: Tag = "div" } = Astro.props satisfies Props;
const hasChildren = Astro.slots.has("default");
---

<Tag
  class={cn(
    "flex flex-col items-center justify-center w-max bg-neutral-200",
    className,
  )}
>
  {hasChildren ? <slot /> : (textContent ?? "No hay contenido para mostrar")}
</Tag>
