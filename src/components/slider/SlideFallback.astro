---
import { cn } from "@lib/utils";
import type { HTMLTag } from "astro/types";

type Props<T extends HTMLTag = "div"> = {
  textContent?: string;
  className?: string;
  as?: T;
};

const { className, textContent, as: Tag = "div" } = Astro.props satisfies Props;
const hasChildren = Astro.slots.has("default");
---

<Tag
  class={cn(
    "flex flex-col items-center justify-center w-full h-auto min-h-12 min-w-12",
    "bg-neutral-200 text-neutral-500 rounded-xl px-4",
    className,
  )}
>
  {hasChildren ? <slot /> : textContent}
</Tag>
