---
import { cn } from "@lib/utils";
import type { HTMLTag } from "astro/types";

type Props<T extends HTMLTag = "div"> = {
  textContent?: string;
  className?: string;
  as?: T;
};

const { className, textContent, as: Tag = "div" } = Astro.props satisfies Props;
const hasChildren = Astro.slots.has("default");
---

<Tag
  class={cn(
    "flex flex-col items-center justify-center w-full h-(--slider-height,100%)",
    "bg-(--fallback-bg,var(--color-neutral-200)) text-(--fallback-color,var(--color-neutral-500)) rounded-(--fallback-radius,0px)",
    "truncate",
    className,
  )}
>
  {hasChildren ? <slot /> : (textContent ?? "No hay contenido para mostrar")}
</Tag>
