---
import SlideFallback from "./SlideFallback.astro";
import type { RenderProps } from "./types";

type Props<T = unknown> = RenderProps<T>;

const { items, fallback: Fallback, render: Item } = Astro.props satisfies Props;
const show = items && items.length > 0 && Item;

function spread<T = unknown>(item: T) {
  return typeof item === "object" ? item : {};
}
---

{
  show ? (
    items.map((item, index) => <Item {...spread(item)} index={index} />)
  ) : (
    <>
      {typeof Fallback === "undefined" && <SlideFallback />}
      {typeof Fallback === "string" && <SlideFallback textContent={Fallback} />}
      {typeof Fallback === "function" && <Fallback />}
    </>
  )
}
