---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { cn } from "@lib/utils";
import RenderArray from "@components/RenderArray.astro";

interface Props<T = null> {
  render?: AstroComponentFactory;
  className?: string;
  items?: T[];
  id: string;
}

const { id, className, items, render } = Astro.props;
---

<div class="overflow-hidden w-full min-w-0" id={id}>
  <div class={cn("flex gap-3", className)}>
    <RenderArray items={items} render={render} />
  </div>
</div>
