---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { cn } from "@lib/utils";
import Render from "@components/slider/Render.astro";
import { getSliderIdFor } from "./utils";

type Props<T = null> = {
  render: AstroComponentFactory;
  className?: string;
  items?: T[];
  id: string;
};

const { id, className, items, render } = Astro.props;
---

<ul
  id={getSliderIdFor(id, "thumbnails")}
  class={cn("flex flex-col gap-2", className)}
>
  <Render items={items} render={render}>
    <slot />
  </Render>
</ul>
