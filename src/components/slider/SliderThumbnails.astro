---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { cn } from "@lib/utils";
import Render from "@components/slider/Render.astro";
import { getSliderIdFor } from "./utils";

type Props<T = null> = {
  render: AstroComponentFactory;
  className?: string;
  items?: T[];
  id: string;
};

const { id, className, items, render } = Astro.props;
---

<ul
  id={getSliderIdFor(id, "thumbnails")}
  class={cn(
    "flex flex-col gap-2 order-last lg:order-first overflow-y-auto lg:overflow-y-scroll [-ms-overflow-style:none] [scrollbar-width:none]",
    "w-(--thumbnail-width,max-content) min-w-(--thumbnail-width,max-content) h-full p-0.5",
    className,
  )}
>
  <Render items={items} render={render}>
    <slot />
  </Render>
</ul>
