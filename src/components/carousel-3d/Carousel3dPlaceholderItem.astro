---
import { cn } from "@lib/utils";

type Props = {
  position?: "center" | "left" | "right";
};

const { position = "center" } = Astro.props;

// Default transforms match the JS defaults (translateX 220, sideScale 0.8, rotateY 21).
// These are SSR fallbacks only — Carousel3D.updatePlaceholder() overrides them
// via inline styles right after initialization, keeping both in sync automatically.
const defaultTransforms = {
  center: "",
  left: "[transform:translateX(-235px)_scale(0.8)_rotateY(55deg)]",
  right: "[transform:translateX(235px)_scale(0.8)_rotateY(-55deg)]",
};
---

<div
  data-c3d-position={position}
  class={cn(
    "absolute w-[275px] h-[271px] rounded-[25px] overflow-hidden shadow-[0_10px_30px_rgba(0,0,0,0.15),0_5px_15px_rgba(0,0,0,0.08)]",
    position === "center" && "z-30",
    position !== "center" && "z-20",
    defaultTransforms[position],
  )}
>
  <slot />
</div>
