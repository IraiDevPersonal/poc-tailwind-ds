---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

type Props<T = null> = {
  render?: AstroComponentFactory;
  items?: T[];
};

const { items, render: Item } = Astro.props satisfies Props;
---

{
  items && Item ? (
    items.map((item, index) => (
      <Item {...(typeof item === "object" ? item : {})} index={index} />
    ))
  ) : (
    <slot />
  )
}
